NEXT_PUBLIC_SANITY_PROJECT_ID=placeholder
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Contact form delivery (Resend). The form at /contact is dormant until all
# three are set — locally in .env.local, and in Vercel (a change there needs a
# manual redeploy). None are NEXT_PUBLIC_: they are server-only and must never
# reach the browser.
#
# CONTACT_FROM must be an address on a domain verified in Resend. Use a
# SUBDOMAIN (send.ndriot.com) so verification never touches the apex MX/SPF/DKIM
# records that ndriot.com email depends on.
RESEND_API_KEY=
CONTACT_FROM=ND Riot <contact@send.ndriot.com>
CONTACT_INBOX=
